generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

// ============================================
// MODELS
// ============================================

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  phone        String?
  passwordHash String
  firstName    String
  lastName     String
  avatar       String?
  role         String  @default("BROKER") // ADMIN, BACKOFFICE, REGIONAL_DIRECTOR, MANAGER, BROKER, ADVERTISER, BUYER
  status       String  @default("PENDING") // PENDING, ACTIVE, SUSPENDED, INACTIVE

  // Hierarchie
  managerId   String?
  manager     User?   @relation("ManagerToBroker", fields: [managerId], references: [id])
  teamMembers User[]  @relation("ManagerToBroker")

  // Region
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  // Profil makléře
  specializations String? // JSON array: ["SUV", "Luxury"]
  cities          String? // JSON array: ["Praha", "Brno"]
  bio             String?
  slug            String? @unique

  // Profil inzerenta (ADVERTISER)
  accountType String? // PRIVATE, DEALER, BAZAAR
  companyName String?
  ico         String? // IČO pro firmy
  icoVerified Boolean @default(false)
  logo        String?

  // Relace
  vehicles        Vehicle[]
  commissions     Commission[]     @relation("BrokerCommissions")
  notifications   Notification[]
  contracts       Contract[]       @relation("BrokerContracts")
  aiConversations AiConversation[]

  // Inzertní platforma relace
  listings  Listing[]
  inquiries Inquiry[]  @relation("BuyerInquiries")
  watchdogs Watchdog[]
  favorites Favorite[]

  // Eshop autodíly relace
  suppliedParts         Part[]
  ordersAsBuyer         Order[]
  orderItemsAsSupplier  OrderItem[]  @relation("SupplierOrderItems")

  // Marketplace relace
  dealerFlips FlipOpportunity[]
  investments Investment[]

  // Auth
  emailVerified DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([managerId])
}

model Region {
  id     String  @id @default(cuid())
  name   String  @unique
  cities String? // JSON array
  users  User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id String @id @default(cuid())

  // VIN
  vin       String  @unique
  vinLocked Boolean @default(false)

  // Základní info
  brand   String
  model   String
  variant String?
  year    Int
  mileage Int
  slug    String? @unique

  // Motor
  fuelType       String // PETROL, DIESEL, ELECTRIC, HYBRID, PLUGIN_HYBRID, LPG, CNG
  transmission   String // MANUAL, AUTOMATIC, DSG, CVT
  enginePower    Int?
  engineCapacity Int?

  // Karoserie
  bodyType   String? // SEDAN, HATCHBACK, COMBI, SUV, COUPE, CABRIO, VAN, PICKUP
  color      String?
  doorsCount Int?
  seatsCount Int?

  // Pohon a historie
  drivetrain        String? // FWD, RWD, AWD, 4WD
  ownerCount        Int?
  serviceBookStatus String? // COMPLETE, PARTIAL, NONE, ELECTRONIC
  odometerStatus    String? // VERIFIED, UNVERIFIED, TAMPERED
  originCountry     String?

  // Stav
  condition     String // NEW, LIKE_NEW, EXCELLENT, GOOD, FAIR, DAMAGED
  stkValidUntil DateTime?
  serviceBook   Boolean   @default(false)

  // Cena a DPH
  price           Int
  priceNegotiable Boolean @default(true)
  vatStatus       String? // DEDUCTIBLE, NON_DEDUCTIBLE, MARGIN_SCHEME

  // Popis
  equipment   String? // JSON array
  description String?
  highlights  String? // JSON array - klíčové přednosti vozidla

  // Zdroj vozidla
  vehicleSource String? // OWNER, DEALER, AUCTION, IMPORT, LEASING_RETURN

  // Status
  status          String  @default("DRAFT") // DRAFT, PENDING, REJECTED, ACTIVE, RESERVED, SOLD, ARCHIVED
  rejectionReason String?

  // Typ prodejce
  sellerType String @default("broker") // broker, private

  // Makléř (null pro soukromé inzeráty)
  brokerId String?
  broker   User?   @relation(fields: [brokerId], references: [id])

  // Kontakt (pro soukromé inzeráty)
  contactName  String?
  contactPhone String?
  contactEmail String?

  // Lead info (kontakt na prodejce pro makléře)
  leadSource  String? // BAZOS, SAUTO, FACEBOOK, REFERRAL, COLD_CALL, OTHER
  leadUrl     String?
  sellerName  String?
  sellerPhone String?
  sellerEmail String?

  // Provize makléře
  commission Int? // výše provize v CZK

  // Inspekce
  inspectionData String? // JSON - kompletní data z prohlídky
  overallRating  Int? // 1-5 hvězdiček

  // Lokace
  city      String
  district  String?
  latitude  Float?
  longitude Float?

  // Trust Score
  trustScore Int @default(0)

  // Stats
  viewCount Int @default(0)

  // Relace
  images      VehicleImage[]
  changeLog   VehicleChangeLog[]
  commissions Commission[]
  contracts   Contract[]
  listing     Listing?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  @@index([brand, model])
  @@index([status])
  @@index([brokerId])
  @@index([price])
  @@index([year])
  @@index([sellerType])
}

model VehicleImage {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url       String
  order     Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([vehicleId])
}

model VehicleChangeLog {
  id         String  @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId     String
  field      String
  oldValue   String?
  newValue   String?
  reason     String?
  flagged    Boolean @default(false)
  flagReason String?

  createdAt DateTime @default(now())

  @@index([vehicleId])
}

model Commission {
  id        String  @id @default(cuid())
  brokerId  String
  broker    User    @relation("BrokerCommissions", fields: [brokerId], references: [id])
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  salePrice  Int
  commission Int
  rate       Float
  status     String @default("PENDING") // PENDING, APPROVED, PAID, CANCELLED

  soldAt DateTime
  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId])
  @@index([status])
  @@index([soldAt])
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type  String // COMMISSION, VEHICLE, SYSTEM, MESSAGE
  title String
  body  String
  link  String?
  read  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model Contract {
  id   String @id @default(cuid())
  type String // BROKERAGE (zprostředkovatelská), HANDOVER (předávací protokol)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  brokerId  String
  broker    User     @relation("BrokerContracts", fields: [brokerId], references: [id])

  // Prodejce
  sellerName        String
  sellerPhone       String
  sellerEmail       String?
  sellerAddress     String?
  sellerIdNumber    String? // Rodné číslo
  sellerIdCard      String? // Číslo OP
  sellerBankAccount String?

  // Obsah smlouvy
  content    String? // JSON - strukturovaná data smlouvy
  price      Int? // Dohodnutá cena
  commission Int? // Provize

  // Podpisy
  sellerSignature String? // Base64 PNG podpisu
  brokerSignature String? // Base64 PNG podpisu
  signedAt        DateTime?
  signedLocation  String? // GPS souřadnice při podpisu

  // PDF
  pdfUrl String? // URL vygenerovaného PDF

  // Stav
  status String @default("DRAFT") // DRAFT, SIGNED, SENT, ARCHIVED

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId])
  @@index([vehicleId])
  @@index([status])
  @@index([createdAt])
}

model AiConversation {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  messages Json // Array of { role: 'user'|'assistant', content: string, timestamp: string }
  context  Json? // { step?: string, vehicleId?: string }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

// ============================================
// INZERTNÍ PLATFORMA
// ============================================

model Listing {
  id          String @id @default(cuid())
  slug        String @unique
  listingType String // PRIVATE, DEALER, BROKER

  // Vlastník inzerátu
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  vehicleId String?  @unique // Odkaz na Vehicle (pokud listing od makléře)
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  // Vozidlo
  vin            String?
  brand          String
  model          String
  variant        String?
  year           Int
  mileage        Int
  fuelType       String // PETROL, DIESEL, ELECTRIC, HYBRID, PLUGIN_HYBRID, LPG, CNG
  transmission   String // MANUAL, AUTOMATIC, DSG, CVT
  enginePower    Int?
  engineCapacity Int?
  bodyType       String? // SEDAN, HATCHBACK, COMBI, SUV, COUPE, CABRIO, VAN, PICKUP
  color          String?
  doorsCount     Int?
  seatsCount     Int?

  // Stav vozidla
  condition      String // NEW, LIKE_NEW, EXCELLENT, GOOD, FAIR, DAMAGED
  serviceBook    Boolean?  @default(false)
  stkValidUntil  DateTime?
  odometerStatus String? // VERIFIED, UNVERIFIED, TAMPERED
  ownerCount     Int?
  originCountry  String?

  // Cena
  price           Int
  priceNegotiable Boolean @default(true)
  vatStatus       String? // DEDUCTIBLE, NON_DEDUCTIBLE, MARGIN_SCHEME

  // Kontakt
  contactName  String
  contactPhone String
  contactEmail String?
  city         String
  district     String?

  // Obsah
  description String?
  equipment   String? // JSON array
  highlights  String? // JSON array

  // Status
  status       String    @default("DRAFT") // DRAFT, ACTIVE, INACTIVE, SOLD, EXPIRED
  isPremium    Boolean   @default(false)
  premiumUntil DateTime?

  // Propojení s makléřskou sítí
  wantsBrokerHelp Boolean @default(false)

  // Stats
  viewCount    Int @default(0)
  inquiryCount Int @default(0)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  expiresAt   DateTime?

  // Relace
  images    ListingImage[]
  inquiries Inquiry[]
  favorites Favorite[]

  @@index([userId])
  @@index([status])
  @@index([brand, model])
  @@index([price])
  @@index([year])
  @@index([city])
  @@index([listingType])
  @@index([isPremium])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  order     Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([listingId])
}

model Inquiry {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  senderId  String?
  sender    User?   @relation("BuyerInquiries", fields: [senderId], references: [id])

  // Kontakt (pro nepřihlášené zájemce)
  name    String
  email   String
  phone   String?
  message String

  // Odpověď inzerenta
  reply     String?
  repliedAt DateTime?

  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([senderId])
}

model Watchdog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Kritéria
  brand    String?
  model    String?
  minPrice Int?
  maxPrice Int?
  minYear  Int?
  maxYear  Int?
  fuelType String?
  bodyType String?
  city     String?

  active       Boolean   @default(true)
  lastNotified DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model Favorite {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// ============================================
// ESHOP AUTODÍLY
// ============================================

model Part {
  id         String @id @default(cuid())
  slug       String @unique
  supplierId String
  supplier   User   @relation(fields: [supplierId], references: [id])

  // Základní info
  category    String // ENGINE, TRANSMISSION, BRAKES, SUSPENSION, BODY, ELECTRICAL, INTERIOR, WHEELS, EXHAUST, COOLING, FUEL, OTHER
  name        String
  description String?
  partNumber  String?
  oemNumber   String?

  // Stav
  condition String // NEW, USED_GOOD, USED_FAIR, USED_POOR, REFURBISHED

  // Cena
  price       Int
  currency    String  @default("CZK")
  vatIncluded Boolean @default(true)

  // Sklad
  stock      Int     @default(1)
  weight     Float?
  dimensions String?

  // Kompatibilita
  compatibleBrands   String?  // JSON array: ["Škoda", "VW"]
  compatibleModels   String?  // JSON array: ["Octavia", "Golf"]
  compatibleYearFrom Int?
  compatibleYearTo   Int?
  universalFit       Boolean @default(false)

  // Status
  status    String @default("DRAFT") // DRAFT, ACTIVE, SOLD, INACTIVE
  viewCount Int    @default(0)

  // Relace
  images     PartImage[]
  orderItems OrderItem[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@index([category])
  @@index([status])
  @@index([price])
}

model PartImage {
  id        String  @id @default(cuid())
  partId    String
  part      Part    @relation(fields: [partId], references: [id], onDelete: Cascade)
  url       String
  order     Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([partId])
}

model Order {
  id          String  @id @default(cuid())
  orderNumber String  @unique
  buyerId     String?
  buyer       User?   @relation(fields: [buyerId], references: [id])

  // Status
  status String @default("PENDING") // PENDING, CONFIRMED, SHIPPED, DELIVERED, CANCELLED

  // Doručení
  deliveryName    String
  deliveryPhone   String
  deliveryEmail   String
  deliveryAddress String
  deliveryCity    String
  deliveryZip     String

  // Platba
  paymentMethod String @default("BANK_TRANSFER") // BANK_TRANSFER, COD
  paymentStatus String @default("PENDING")        // PENDING, PAID

  // Ceny
  totalPrice    Int
  shippingPrice Int @default(0)

  // Poznámka
  note String?

  // Tracking
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  // Relace
  items OrderItem[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([status])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partId     String
  part       Part   @relation(fields: [partId], references: [id])
  supplierId String
  supplier   User   @relation("SupplierOrderItems", fields: [supplierId], references: [id])

  quantity   Int
  unitPrice  Int
  totalPrice Int

  status String @default("PENDING") // PENDING, CONFIRMED, SHIPPED

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([partId])
  @@index([supplierId])
}

// ============================================
// MARKETPLACE — INVESTIČNÍ PLATFORMA
// ============================================

model FlipOpportunity {
  id       String @id @default(cuid())
  dealerId String
  dealer   User   @relation(fields: [dealerId], references: [id])

  // Auto
  brand     String
  model     String
  year      Int
  mileage   Int
  vin       String?
  condition String // NEW, LIKE_NEW, EXCELLENT, GOOD, FAIR, DAMAGED
  photos    String? // JSON array of URLs

  // Finance
  purchasePrice      Int
  repairCost         Int
  estimatedSalePrice Int

  // Opravy
  repairDescription String?
  repairPhotos      String? // JSON array of URLs

  // Prodej
  actualSalePrice Int?
  soldAt          DateTime?

  // Status
  status          String @default("PENDING_APPROVAL")
  // PENDING_APPROVAL, APPROVED, FUNDING, FUNDED, IN_REPAIR, FOR_SALE, SOLD, PAYOUT_PENDING, COMPLETED, CANCELLED
  fundedAmount    Int    @default(0)
  adminNotes      String?
  rejectionReason String?

  // Relace
  investments Investment[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealerId])
  @@index([status])
}

model Investment {
  id            String          @id @default(cuid())
  investorId    String
  investor      User            @relation(fields: [investorId], references: [id])
  opportunityId String
  opportunity   FlipOpportunity @relation(fields: [opportunityId], references: [id])

  amount           Int
  paymentStatus    String @default("PENDING") // PENDING, CONFIRMED, REFUNDED
  paymentReference String?

  // Výplata
  returnAmount Int?
  paidOutAt    DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@index([opportunityId])
  @@index([paymentStatus])
}
