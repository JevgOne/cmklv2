generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

// ============================================
// MODELS
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?
  passwordHash String
  firstName    String
  lastName     String
  avatar       String?
  role         String   @default("BROKER") // ADMIN, BACKOFFICE, REGIONAL_DIRECTOR, MANAGER, BROKER
  status       String   @default("PENDING") // PENDING, ACTIVE, SUSPENDED, INACTIVE

  // Hierarchie
  managerId   String?
  manager     User?  @relation("ManagerToBroker", fields: [managerId], references: [id])
  teamMembers User[] @relation("ManagerToBroker")

  // Region
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  // Profil makléře
  specializations String? // JSON array: ["SUV", "Luxury"]
  cities          String? // JSON array: ["Praha", "Brno"]
  bio             String?
  slug            String? @unique

  // Relace
  vehicles      Vehicle[]
  commissions   Commission[] @relation("BrokerCommissions")
  notifications Notification[]

  // Auth
  emailVerified DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([managerId])
}

model Region {
  id     String @id @default(cuid())
  name   String @unique
  cities String? // JSON array
  users  User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id String @id @default(cuid())

  // VIN
  vin       String  @unique
  vinLocked Boolean @default(false)

  // Základní info
  brand   String
  model   String
  variant String?
  year    Int
  mileage Int
  slug    String? @unique

  // Motor
  fuelType       String // PETROL, DIESEL, ELECTRIC, HYBRID, PLUGIN_HYBRID, LPG, CNG
  transmission   String // MANUAL, AUTOMATIC, DSG, CVT
  enginePower    Int?
  engineCapacity Int?

  // Karoserie
  bodyType   String? // SEDAN, HATCHBACK, COMBI, SUV, COUPE, CABRIO, VAN, PICKUP
  color      String?
  doorsCount Int?
  seatsCount Int?

  // Stav
  condition     String // NEW, LIKE_NEW, EXCELLENT, GOOD, FAIR, DAMAGED
  stkValidUntil DateTime?
  serviceBook   Boolean @default(false)

  // Cena
  price           Int
  priceNegotiable Boolean @default(true)

  // Popis
  equipment   String? // JSON array
  description String?

  // Status
  status String @default("DRAFT") // DRAFT, PENDING, REJECTED, ACTIVE, RESERVED, SOLD, ARCHIVED

  // Typ prodejce
  sellerType String @default("broker") // broker, private

  // Makléř (null pro soukromé inzeráty)
  brokerId String?
  broker   User?  @relation(fields: [brokerId], references: [id])

  // Kontakt (pro soukromé inzeráty)
  contactName  String?
  contactPhone String?
  contactEmail String?

  // Lokace
  city      String
  district  String?
  latitude  Float?
  longitude Float?

  // Trust Score
  trustScore Int @default(0)

  // Stats
  viewCount Int @default(0)

  // Relace
  images      VehicleImage[]
  changeLog   VehicleChangeLog[]
  commissions Commission[]

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  @@index([brand, model])
  @@index([status])
  @@index([brokerId])
  @@index([price])
  @@index([year])
  @@index([sellerType])
}

model VehicleImage {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url       String
  order     Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([vehicleId])
}

model VehicleChangeLog {
  id         String  @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId     String
  field      String
  oldValue   String?
  newValue   String?
  reason     String?
  flagged    Boolean @default(false)
  flagReason String?

  createdAt DateTime @default(now())

  @@index([vehicleId])
}

model Commission {
  id        String   @id @default(cuid())
  brokerId  String
  broker    User     @relation("BrokerCommissions", fields: [brokerId], references: [id])
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  salePrice  Int
  commission Int
  rate       Float
  status     String   @default("PENDING") // PENDING, APPROVED, PAID, CANCELLED

  soldAt  DateTime
  paidAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId])
  @@index([status])
  @@index([soldAt])
}

model Notification {
  id     String  @id @default(cuid())
  userId String
  user   User    @relation(fields: [userId], references: [id])

  type  String  // COMMISSION, VEHICLE, SYSTEM, MESSAGE
  title String
  body  String
  link  String?
  read  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
