generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

// ============================================
// MODELS
// ============================================

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  phone        String?
  passwordHash String
  firstName    String
  lastName     String
  avatar       String?
  role         String  @default("BROKER") // ADMIN, BACKOFFICE, REGIONAL_DIRECTOR, MANAGER, BROKER, ADVERTISER, BUYER
  status       String  @default("PENDING") // PENDING, ACTIVE, SUSPENDED, INACTIVE

  // Hierarchie
  managerId   String?
  manager     User?   @relation("ManagerToBroker", fields: [managerId], references: [id])
  teamMembers User[]  @relation("ManagerToBroker")

  // Region
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  // Gamifikace
  level      String @default("JUNIOR") // JUNIOR, BROKER, SENIOR, TOP
  totalSales Int    @default(0)

  // Profil makléře
  specializations String? // JSON array: ["SUV", "Luxury"]
  cities          String? // JSON array: ["Praha", "Brno"]
  bio             String?
  slug            String? @unique

  // Onboarding makléře
  bankAccount         String?  // IBAN pro výplatu provizí
  documents           String?  // JSON: { tradeLicense?: string, idFront?: string, idBack?: string }
  onboardingStep      Int      @default(1) // 1-5 aktuální krok onboardingu
  onboardingCompleted Boolean  @default(false)
  quizScore           Int?     // Výsledek kvízu (procenta)
  brokerContractUrl   String?  // URL podepsané smlouvy s Carmakler
  brokerSignature     String?  // Base64 PNG podpisu makléře (onboarding smlouva)
  quickModeEnabled    Boolean  @default(false) // Rychlé nabírání (Makléř+ level)

  // Profil inzerenta (ADVERTISER)
  accountType String? // PRIVATE, DEALER, BAZAAR
  companyName String?
  ico         String? // IČO pro firmy/makléře
  icoVerified Boolean @default(false)
  logo        String?

  // Relace
  vehicles        Vehicle[]
  commissions     Commission[]     @relation("BrokerCommissions")
  notifications   Notification[]
  contracts       Contract[]       @relation("BrokerContracts")
  aiConversations AiConversation[]
  sentInvitations Invitation[]     @relation("ManagerInvitations")

  // Email systém
  emailLogs EmailLog[] @relation("SenderEmails")

  // Gamifikace relace
  achievements UserAchievement[]

  // Notifikační preference
  notificationPreferences NotificationPreference[]

  // Prodejní flow relace
  vehicleInquiries VehicleInquiry[] @relation("BrokerInquiries")
  damageReports    DamageReport[]   @relation("DamageReports")

  // Lead management relace
  assignedLeads   Lead[]           @relation("AssignedLeads")
  assignedByLeads Lead[]           @relation("AssignedByLeads")

  // CRM relace
  sellerContacts       SellerContact[]       @relation("BrokerContacts")
  sellerCommunications SellerCommunication[] @relation("BrokerCommunications")

  // Eskalace
  escalationsAsBroker  Escalation[] @relation("BrokerEscalations")
  escalationsAsManager Escalation[] @relation("ManagerEscalations")

  // Inzertní platforma relace
  listings  Listing[]
  inquiries Inquiry[]  @relation("BuyerInquiries")
  watchdogs Watchdog[]
  favorites Favorite[]

  // Eshop autodíly relace
  suppliedParts         Part[]
  ordersAsBuyer         Order[]
  orderItemsAsSupplier  OrderItem[]  @relation("SupplierOrderItems")

  // Marketplace relace
  dealerFlips FlipOpportunity[]
  investments Investment[]

  // Platební systém relace
  confirmedPayments Payment[]      @relation("PaymentConfirmer")
  brokerPayouts     BrokerPayout[] @relation("BrokerPayouts")
  approvedPayouts   BrokerPayout[] @relation("PayoutApprover")

  // Auth
  emailVerified DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([status])
  @@index([managerId])
}

model Region {
  id     String  @id @default(cuid())
  name   String  @unique
  cities String? // JSON array
  users  User[]

  invitations Invitation[]
  leads       Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// ONBOARDING MAKLÉŘŮ
// ============================================

model Invitation {
  id        String @id @default(cuid())
  email     String
  name      String?
  token     String @unique
  managerId String
  manager   User   @relation("ManagerInvitations", fields: [managerId], references: [id])
  regionId  String
  region    Region @relation(fields: [regionId], references: [id])
  status    String @default("PENDING") // PENDING, USED, EXPIRED
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([managerId])
  @@index([status])
}

model Vehicle {
  id String @id @default(cuid())

  // VIN
  vin       String  @unique
  vinLocked Boolean @default(false)

  // Základní info
  brand   String
  model   String
  variant String?
  year    Int
  mileage Int
  slug    String? @unique

  // Motor
  fuelType       String // PETROL, DIESEL, ELECTRIC, HYBRID, PLUGIN_HYBRID, LPG, CNG
  transmission   String // MANUAL, AUTOMATIC, DSG, CVT
  enginePower    Int?
  engineCapacity Int?

  // Karoserie
  bodyType   String? // SEDAN, HATCHBACK, COMBI, SUV, COUPE, CABRIO, VAN, PICKUP
  color      String?
  doorsCount Int?
  seatsCount Int?

  // Pohon a historie
  drivetrain        String? // FWD, RWD, AWD, 4WD
  ownerCount        Int?
  serviceBookStatus String? // COMPLETE, PARTIAL, NONE, ELECTRONIC
  odometerStatus    String? // VERIFIED, UNVERIFIED, TAMPERED
  originCountry     String?

  // Stav
  condition     String // NEW, LIKE_NEW, EXCELLENT, GOOD, FAIR, DAMAGED
  stkValidUntil DateTime?
  serviceBook   Boolean   @default(false)

  // Cena a DPH
  price           Int
  priceNegotiable Boolean @default(true)
  vatStatus       String? // DEDUCTIBLE, NON_DEDUCTIBLE, MARGIN_SCHEME

  // Popis
  equipment   String? // JSON array
  description String?
  highlights  String? // JSON array - klíčové přednosti vozidla

  // Zdroj vozidla
  vehicleSource String? // OWNER, DEALER, AUCTION, IMPORT, LEASING_RETURN

  // Status
  status             String    @default("DRAFT") // DRAFT, DRAFT_QUICK, PENDING, REJECTED, ACTIVE, RESERVED, SOLD, ARCHIVED
  rejectionReason    String?
  quickDraftDeadline DateTime? // 48h deadline pro doplnění rychlého draftu

  // Typ prodejce
  sellerType String @default("broker") // broker, private

  // Makléř (null pro soukromé inzeráty)
  brokerId String?
  broker   User?   @relation(fields: [brokerId], references: [id])

  // Kontakt (pro soukromé inzeráty)
  contactName  String?
  contactPhone String?
  contactEmail String?

  // Lead info (kontakt na prodejce pro makléře)
  leadSource  String? // BAZOS, SAUTO, FACEBOOK, REFERRAL, COLD_CALL, OTHER
  leadUrl     String?
  sellerName  String?
  sellerPhone String?
  sellerEmail String?

  // Provize makléře
  commission Int? // výše provize v CZK

  // Inspekce
  inspectionData String? // JSON - kompletní data z prohlídky
  overallRating  Int? // 1-5 hvězdiček

  // Lokace
  city      String
  district  String?
  latitude  Float?
  longitude Float?

  // Trust Score
  trustScore Int @default(0)

  // Stats
  viewCount Int @default(0)

  // Exkluzivita
  exclusiveUntil      DateTime? // Datum konce exkluzivity
  exclusiveContractId String?   // ID propojené exkluzivní smlouvy

  // Rezervace a prodej
  reservedFor        String?
  reservedAt         DateTime?
  reservedPrice      Int?
  soldPrice          Int?
  soldAt             DateTime?
  handoverCompleted  Boolean   @default(false)
  handoverDate       DateTime?

  // CRM — propojení na prodejce
  sellerContactId String?
  sellerContact   SellerContact? @relation(fields: [sellerContactId], references: [id])

  // Relace
  images        VehicleImage[]
  changeLog     VehicleChangeLog[]
  commissions   Commission[]
  contracts     Contract[]
  listing       Listing?
  leads         Lead[]
  inquiries     VehicleInquiry[]
  damageReports DamageReport[]
  payments        Payment[]
  sellerPayouts   SellerPayout[]
  emailLogs       EmailLog[]
  priceReductions PriceReduction[]
  escalations     Escalation[]

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  @@index([brand, model])
  @@index([status])
  @@index([brokerId])
  @@index([price])
  @@index([year])
  @@index([sellerType])
}

model VehicleImage {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  url       String
  order     Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([vehicleId])
}

model VehicleChangeLog {
  id         String  @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId     String
  field      String
  oldValue   String?
  newValue   String?
  reason     String?
  flagged    Boolean @default(false)
  flagReason String?

  createdAt DateTime @default(now())

  @@index([vehicleId])
}

// ============================================
// PRODEJNÍ FLOW
// ============================================

model VehicleInquiry {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  brokerId  String
  broker    User    @relation("BrokerInquiries", fields: [brokerId], references: [id])

  // Kupující
  buyerName  String
  buyerPhone String
  buyerEmail String?
  message    String

  // Stav dotazu
  status String @default("NEW") // NEW, REPLIED, VIEWING_SCHEDULED, NEGOTIATING, RESERVED, SOLD, NO_INTEREST

  // Odpověď makléře
  reply     String?
  repliedAt DateTime?

  // Prohlídka
  viewingDate   DateTime?
  viewingResult String? // INTERESTED, THINKING, NO_INTEREST

  // Cena
  offeredPrice Int?
  agreedPrice  Int?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
  @@index([brokerId])
  @@index([status])
  @@index([createdAt])
}

model DamageReport {
  id           String  @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  reportedById String
  reportedBy   User    @relation("DamageReports", fields: [reportedById], references: [id])

  description String
  severity    String // COSMETIC, FUNCTIONAL, SEVERE
  images      String? // JSON array of image URLs

  repaired   Boolean   @default(false)
  repairedAt DateTime?
  repairNote String?

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([reportedById])
}

model Commission {
  id        String  @id @default(cuid())
  brokerId  String
  broker    User    @relation("BrokerCommissions", fields: [brokerId], references: [id])
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  salePrice  Int
  commission Int
  rate       Float
  status     String @default("PENDING") // PENDING, APPROVED, PAID, CANCELLED

  // Rozdělení provize
  brokerShare  Int? // 50% provize (makléřova část)
  companyShare Int? // 50% provize (firemní část)
  managerBonus Int? // Bonus manažera (2 500 Kč)

  // Propojení na výplaty
  payoutId String?
  payout   BrokerPayout? @relation(fields: [payoutId], references: [id])

  soldAt DateTime
  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId])
  @@index([status])
  @@index([soldAt])
  @@index([payoutId])
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type  String // COMMISSION, VEHICLE, SYSTEM, MESSAGE
  title String
  body  String
  link  String?
  read  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model Contract {
  id   String @id @default(cuid())
  type String // BROKERAGE (zprostředkovatelská), HANDOVER (předávací protokol)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  brokerId  String
  broker    User     @relation("BrokerContracts", fields: [brokerId], references: [id])

  // Prodejce
  sellerName        String
  sellerPhone       String
  sellerEmail       String?
  sellerAddress     String?
  sellerIdNumber    String? // Rodné číslo
  sellerIdCard      String? // Číslo OP
  sellerBankAccount String?

  // Obsah smlouvy
  content    String? // JSON - strukturovaná data smlouvy
  price      Int? // Dohodnutá cena
  commission Int? // Provize

  // Exkluzivita
  exclusiveDuration  Int?      // Doba exkluzivity v měsících
  exclusiveStartDate DateTime? // Začátek exkluzivity
  exclusiveEndDate   DateTime? // Konec exkluzivity

  // Ukončení smlouvy
  earlyTermination  Boolean   @default(false)
  terminationReason String?
  terminationDate   DateTime?

  // Porušení exkluzivity
  violationReported Boolean @default(false)
  violationDetails  String?
  penaltyAmount     Int?    // Smluvní pokuta v CZK

  // Podpisy
  sellerSignature String? // Base64 PNG podpisu
  brokerSignature String? // Base64 PNG podpisu
  signedAt        DateTime?
  signedLocation  String? // GPS souřadnice při podpisu

  // PDF
  pdfUrl String? // URL vygenerovaného PDF

  // Stav
  status String @default("DRAFT") // DRAFT, SIGNED, SENT, ARCHIVED, EXPIRED, TERMINATED

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId])
  @@index([vehicleId])
  @@index([status])
  @@index([createdAt])
}

model AiConversation {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  messages Json // Array of { role: 'user'|'assistant', content: string, timestamp: string }
  context  Json? // { step?: string, vehicleId?: string }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

// ============================================
// LEAD MANAGEMENT
// ============================================

model Lead {
  id String @id @default(cuid())

  // Kontakt
  name  String
  phone String
  email String?

  // Auto info
  brand         String?
  model         String?
  year          Int?
  mileage       Int?
  expectedPrice Int?
  description   String?

  // Zdroj
  source       String // WEB_FORM, EXTERNAL_APP, MANUAL, REFERRAL
  externalId   String?
  sourceDetail String?

  // Lokace
  city     String?
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  // Přiřazení
  assignedToId String?
  assignedTo   User?    @relation("AssignedLeads", fields: [assignedToId], references: [id])
  assignedById String?
  assignedBy   User?    @relation("AssignedByLeads", fields: [assignedById], references: [id])
  assignedAt   DateTime?

  // Stav
  status          String @default("NEW") // NEW, ASSIGNED, CONTACTED, MEETING_SCHEDULED, VEHICLE_ADDED, REJECTED, EXPIRED
  rejectionReason String?
  meetingDate     DateTime?

  // Propojení na vozidlo
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([regionId])
  @@index([source])
  @@index([phone, brand, model])
}

// ============================================
// INZERTNÍ PLATFORMA
// ============================================

model Listing {
  id          String @id @default(cuid())
  slug        String @unique
  listingType String // PRIVATE, DEALER, BROKER

  // Vlastník inzerátu
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  vehicleId String?  @unique // Odkaz na Vehicle (pokud listing od makléře)
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  // Vozidlo
  vin            String?
  brand          String
  model          String
  variant        String?
  year           Int
  mileage        Int
  fuelType       String // PETROL, DIESEL, ELECTRIC, HYBRID, PLUGIN_HYBRID, LPG, CNG
  transmission   String // MANUAL, AUTOMATIC, DSG, CVT
  enginePower    Int?
  engineCapacity Int?
  bodyType       String? // SEDAN, HATCHBACK, COMBI, SUV, COUPE, CABRIO, VAN, PICKUP
  color          String?
  doorsCount     Int?
  seatsCount     Int?

  // Stav vozidla
  condition      String // NEW, LIKE_NEW, EXCELLENT, GOOD, FAIR, DAMAGED
  serviceBook    Boolean?  @default(false)
  stkValidUntil  DateTime?
  odometerStatus String? // VERIFIED, UNVERIFIED, TAMPERED
  ownerCount     Int?
  originCountry  String?

  // Cena
  price           Int
  priceNegotiable Boolean @default(true)
  vatStatus       String? // DEDUCTIBLE, NON_DEDUCTIBLE, MARGIN_SCHEME

  // Kontakt
  contactName  String
  contactPhone String
  contactEmail String?
  city         String
  district     String?

  // Obsah
  description String?
  equipment   String? // JSON array
  highlights  String? // JSON array

  // Status
  status       String    @default("DRAFT") // DRAFT, ACTIVE, INACTIVE, SOLD, EXPIRED
  isPremium    Boolean   @default(false)
  premiumUntil DateTime?

  // Propojení s makléřskou sítí
  wantsBrokerHelp Boolean @default(false)

  // Stats
  viewCount    Int @default(0)
  inquiryCount Int @default(0)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  expiresAt   DateTime?

  // Relace
  images    ListingImage[]
  inquiries Inquiry[]
  favorites Favorite[]

  @@index([userId])
  @@index([status])
  @@index([brand, model])
  @@index([price])
  @@index([year])
  @@index([city])
  @@index([listingType])
  @@index([isPremium])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  order     Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([listingId])
}

model Inquiry {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  senderId  String?
  sender    User?   @relation("BuyerInquiries", fields: [senderId], references: [id])

  // Kontakt (pro nepřihlášené zájemce)
  name    String
  email   String
  phone   String?
  message String

  // Odpověď inzerenta
  reply     String?
  repliedAt DateTime?

  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([listingId])
  @@index([senderId])
}

model Watchdog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Kritéria
  brand    String?
  model    String?
  minPrice Int?
  maxPrice Int?
  minYear  Int?
  maxYear  Int?
  fuelType String?
  bodyType String?
  city     String?

  active       Boolean   @default(true)
  lastNotified DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model Favorite {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// ============================================
// ESHOP AUTODÍLY
// ============================================

model Part {
  id         String @id @default(cuid())
  slug       String @unique
  supplierId String
  supplier   User   @relation(fields: [supplierId], references: [id])

  // Základní info
  category    String // ENGINE, TRANSMISSION, BRAKES, SUSPENSION, BODY, ELECTRICAL, INTERIOR, WHEELS, EXHAUST, COOLING, FUEL, OTHER
  name        String
  description String?
  partNumber  String?
  oemNumber   String?

  // Stav
  condition String // NEW, USED_GOOD, USED_FAIR, USED_POOR, REFURBISHED

  // Cena
  price       Int
  currency    String  @default("CZK")
  vatIncluded Boolean @default(true)

  // Sklad
  stock      Int     @default(1)
  weight     Float?
  dimensions String?

  // Kompatibilita
  compatibleBrands   String?  // JSON array: ["Škoda", "VW"]
  compatibleModels   String?  // JSON array: ["Octavia", "Golf"]
  compatibleYearFrom Int?
  compatibleYearTo   Int?
  universalFit       Boolean @default(false)

  // Status
  status    String @default("DRAFT") // DRAFT, ACTIVE, SOLD, INACTIVE
  viewCount Int    @default(0)

  // Relace
  images     PartImage[]
  orderItems OrderItem[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@index([category])
  @@index([status])
  @@index([price])
}

model PartImage {
  id        String  @id @default(cuid())
  partId    String
  part      Part    @relation(fields: [partId], references: [id], onDelete: Cascade)
  url       String
  order     Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([partId])
}

model Order {
  id          String  @id @default(cuid())
  orderNumber String  @unique
  buyerId     String?
  buyer       User?   @relation(fields: [buyerId], references: [id])

  // Status
  status String @default("PENDING") // PENDING, CONFIRMED, SHIPPED, DELIVERED, CANCELLED

  // Doručení
  deliveryName    String
  deliveryPhone   String
  deliveryEmail   String
  deliveryAddress String
  deliveryCity    String
  deliveryZip     String

  // Platba
  paymentMethod String @default("BANK_TRANSFER") // BANK_TRANSFER, COD
  paymentStatus String @default("PENDING")        // PENDING, PAID

  // Ceny
  totalPrice    Int
  shippingPrice Int @default(0)

  // Poznámka
  note String?

  // Tracking
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  // Relace
  items OrderItem[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([status])
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partId     String
  part       Part   @relation(fields: [partId], references: [id])
  supplierId String
  supplier   User   @relation("SupplierOrderItems", fields: [supplierId], references: [id])

  quantity   Int
  unitPrice  Int
  totalPrice Int

  status String @default("PENDING") // PENDING, CONFIRMED, SHIPPED

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([partId])
  @@index([supplierId])
}

// ============================================
// MARKETPLACE — INVESTIČNÍ PLATFORMA
// ============================================

model FlipOpportunity {
  id       String @id @default(cuid())
  dealerId String
  dealer   User   @relation(fields: [dealerId], references: [id])

  // Auto
  brand     String
  model     String
  year      Int
  mileage   Int
  vin       String?
  condition String // NEW, LIKE_NEW, EXCELLENT, GOOD, FAIR, DAMAGED
  photos    String? // JSON array of URLs

  // Finance
  purchasePrice      Int
  repairCost         Int
  estimatedSalePrice Int

  // Opravy
  repairDescription String?
  repairPhotos      String? // JSON array of URLs

  // Prodej
  actualSalePrice Int?
  soldAt          DateTime?

  // Status
  status          String @default("PENDING_APPROVAL")
  // PENDING_APPROVAL, APPROVED, FUNDING, FUNDED, IN_REPAIR, FOR_SALE, SOLD, PAYOUT_PENDING, COMPLETED, CANCELLED
  fundedAmount    Int    @default(0)
  adminNotes      String?
  rejectionReason String?

  // Relace
  investments Investment[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealerId])
  @@index([status])
}

model Investment {
  id            String          @id @default(cuid())
  investorId    String
  investor      User            @relation(fields: [investorId], references: [id])
  opportunityId String
  opportunity   FlipOpportunity @relation(fields: [opportunityId], references: [id])

  amount           Int
  paymentStatus    String @default("PENDING") // PENDING, CONFIRMED, REFUNDED
  paymentReference String?

  // Výplata
  returnAmount Int?
  paidOutAt    DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([investorId])
  @@index([opportunityId])
  @@index([paymentStatus])
}

// ============================================
// PLATEBNÍ SYSTÉM
// ============================================

model Payment {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  // Kupující
  buyerName  String
  buyerEmail String
  buyerPhone String?

  // Platba
  amount Int    // Celková částka (prodejní cena) v CZK
  method String // CARD, BANK_TRANSFER, FINANCING
  status String @default("PENDING") // PENDING, PROCESSING, PAID, FAILED, REFUNDED

  // Stripe
  stripeSessionId     String? // Stripe Checkout Session ID
  stripePaymentIntent String? // Payment Intent ID

  // Bankovní převod
  variableSymbol String? // Variabilní symbol (pro převody)

  // Potvrzení
  confirmedAt   DateTime?
  confirmedById String?
  confirmedBy   User?    @relation("PaymentConfirmer", fields: [confirmedById], references: [id])

  // Relace
  sellerPayouts SellerPayout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
  @@index([status])
  @@index([stripeSessionId])
  @@index([variableSymbol])
}

model SellerPayout {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id])

  sellerName        String
  sellerBankAccount String
  amount            Int    // Prodejní cena - provize
  commissionAmount  Int    // Stržená provize

  status        String    @default("PENDING") // PENDING, PROCESSING, PAID, FAILED
  paidAt        DateTime?
  bankReference String?   // Reference bankovního převodu

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([paymentId])
  @@index([status])
}

model BrokerPayout {
  id       String @id @default(cuid())
  brokerId String
  broker   User   @relation("BrokerPayouts", fields: [brokerId], references: [id])
  period   String // "2026-03" (rok-měsíc)

  commissions   Commission[] // Provize zahrnuté v této výplatě
  totalAmount   Int          // Celková částka k výplatě (50% z provizí)
  invoiceUrl    String?      // URL nahrané faktury od makléře
  invoiceNumber String?      // Číslo faktury

  status       String    @default("PENDING_INVOICE") // PENDING_INVOICE, INVOICE_UPLOADED, APPROVED, PAID
  approvedById String?
  approvedBy   User?     @relation("PayoutApprover", fields: [approvedById], references: [id])
  paidAt       DateTime?

  createdAt DateTime @default(now())

  @@index([brokerId])
  @@index([period])
  @@index([status])
}

// ============================================
// CRM PRODEJCŮ
// ============================================

model SellerContact {
  id       String @id @default(cuid())
  brokerId String
  broker   User   @relation("BrokerContacts", fields: [brokerId], references: [id])

  name    String
  phone   String
  email   String?
  address String?
  city    String?
  note    String?

  // Propojení s vozidly
  vehicles Vehicle[]

  // Statistiky
  totalVehicles Int @default(0)
  totalSold     Int @default(0)
  lastContactAt DateTime?

  // Follow-up
  nextFollowUp DateTime?
  followUpNote String?

  // Komunikace
  communications SellerCommunication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId])
  @@index([phone])
  @@index([nextFollowUp])
}

model SellerCommunication {
  id        String        @id @default(cuid())
  contactId String
  contact   SellerContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  brokerId  String
  broker    User          @relation("BrokerCommunications", fields: [brokerId], references: [id])

  type      String  // CALL, SMS, EMAIL, MEETING, NOTE
  direction String? // OUTGOING, INCOMING
  summary   String
  duration  Int?    // Délka hovoru v sekundách
  result    String? // INTERESTED, NOT_NOW, REJECTED, FOLLOW_UP

  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([brokerId])
}

// ============================================
// GAMIFIKACE
// ============================================

model UserAchievement {
  id             String @id @default(cuid())
  userId         String
  user           User   @relation(fields: [userId], references: [id])
  achievementKey String // FIRST_VEHICLE, FIRST_SALE, QUICK_SALE, FIVE_SALES, TEN_SALES, MILLIONAIRE, PHOTO_PRO, PERFECTIONIST, LOYAL_CLIENT
  unlockedAt     DateTime @default(now())

  @@unique([userId, achievementKey])
  @@index([userId])
}

model PriceReduction {
  id             String   @id @default(cuid())
  vehicleId      String
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id])
  currentPrice   Int
  suggestedPrice Int
  reason         String   // Důvod návrhu snížení
  status         String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, MODIFIED
  acceptedPrice  Int?     // Cena po úpravě makléřem
  respondedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([status])
}

// ============================================
// ESKALACE
// ============================================

model Escalation {
  id        String @id @default(cuid())
  brokerId  String
  broker    User   @relation("BrokerEscalations", fields: [brokerId], references: [id])
  managerId String?
  manager   User?  @relation("ManagerEscalations", fields: [managerId], references: [id])

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  contactId   String?

  type        String  // SELLER_ISSUE, FRAUD_SUSPICION, TECHNICAL, EXCLUSIVITY_VIOLATION, OTHER
  urgency     String  @default("NORMAL") // NORMAL, URGENT
  description String
  attachments String? // JSON array of URLs
  status      String  @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  resolution  String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([brokerId])
  @@index([managerId])
  @@index([vehicleId])
  @@index([status])
}

// ============================================
// EMAIL LOG
// ============================================

model EmailLog {
  id        String   @id @default(cuid())
  senderId  String?
  sender    User?    @relation("SenderEmails", fields: [senderId], references: [id])
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  recipientEmail String
  recipientName  String?
  subject        String
  templateType   String  // PRESENTATION, CONTRACT_OFFER, FOLLOWUP, INSURANCE, FINANCING, PRICE_CHANGE, VEHICLE_SOLD, VEHICLE_APPROVED, NEW_INQUIRY, VIEWING_SCHEDULED, PRICE_REDUCTION, DAILY_SUMMARY, WELCOME
  customText     String? // Vlastní text přidaný makléřem
  status         String  @default("SENT") // SENT, DELIVERED, OPENED, FAILED, BOUNCED
  resendId       String? // ID z Resend API

  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([vehicleId])
  @@index([templateType])
  @@index([createdAt])
}

// ============================================
// NOTIFIKAČNÍ PREFERENCE + SMS LOG
// ============================================

model NotificationPreference {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id])
  eventType    String  // NEW_LEAD, NEW_INQUIRY, VEHICLE_APPROVED, VEHICLE_REJECTED, VEHICLE_SOLD, DAILY_SUMMARY, VEHICLE_30_DAYS, ACHIEVEMENT, LEADERBOARD
  pushEnabled  Boolean @default(true)
  emailEnabled Boolean @default(true)
  smsEnabled   Boolean @default(false)

  @@unique([userId, eventType])
  @@index([userId])
}

model SmsLog {
  id             String   @id @default(cuid())
  recipientPhone String
  message        String
  vehicleId      String?
  status         String   // SENT, DELIVERED, FAILED
  cost           Float?
  createdAt      DateTime @default(now())

  @@index([recipientPhone])
  @@index([createdAt])
}

